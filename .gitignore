# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.Python
build/
dist/
*.so
.venv/
venv/
ENV/

# ── Environment variables — NEVER commit these ────────────────
.env
.env.local
.env.*.local
!.env.example

# ── ML generated files (regenerated by scripts) ───────────────
ml/data/*.csv
ml/data/*.png
ml/data/*.json
ml/data/*.txt
# Keep metadata and feature names in git
!ml/data/metadata.json
!ml/data/model_feature_names.json

# ── Node / Frontend ───────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.vite/
*.local

# ── Docker ────────────────────────────────────────────────────
.docker/

# ── VSCode ────────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
!.vscode/extensions.json   # keep extension recommendations

# ── OS ────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/
pip-log.txt
npm-debug.log*

# ── Testing ───────────────────────────────────────────────────
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# ── Jupyter ───────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Misc ──────────────────────────────────────────────────────
*.bak
*.swp
*.tmp